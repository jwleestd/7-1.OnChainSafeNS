│   │   ├── 001-project-overview.md
│   │   ├── 002-tech-stack.md
│   │   ├── 003-development-guidelines.md
│   │   ├── 004-phase0-constraints.md    ★ NEW
│   │   └── 005-data-model.md            ★ NEW
│   ├── skills/                  ← 4개 MVP 스킬 (= .cursor/skills 미러)
│   │   ├── error-fixing/SKILL.md        ★ NEW
│   │   ├── build-and-setup/SKILL.md     ★ NEW
│   │   ├── git-commit-pr/SKILL.md       ★ NEW
│   │   └── generate-tasks-from-srs/SKILL.md  ★ NEW
│   └── workflows/               ← 2개 워크플로우
│       ├── generate-tasks-from-srs.md   ✏️ UPDATED
│       └── generate-agent-rule.md       ✏️ UPDATED
│
├── .cursor/                     ← Cursor 전용
│   ├── rules/                   ← 18개 규칙 파일
│   │   ├── 000-meta-rule-script.mdc     ✏️ UPDATED
│   │   ├── 001~003 (Core)               ✏️ UPDATED
│   │   ├── 010~012 (Meta)               ✅ 유지
│   │   ├── 100~102 (Workflow)           ✏️ 101 UPDATED
│   │   ├── 200~202 (Pattern)            ✅ 유지
│   │   └── 300~304 (Tech-specific)      ★ NEW (4개)
│   ├── skills/                  ← 4개 MVP 스킬
│   │   └── (error-fixing, build-and-setup, git-commit-pr, generate-tasks-from-srs)
│   └── agents/
│       └── document-updater.md          ✏️ UPDATED
│
├── .claude/                     ← Claude Code 전용
│   └── agents/
